{
  "$ref": "#/definitions/BunnyJson",
  "definitions": {
    "BunnyJson": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "deploy": {
          "type": "object",
          "properties": {
            "publicDir": {
              "type": "string",
              "minLength": 1
            },
            "ignore": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "mimeTypes": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "minLength": 1
              },
              "propertyNames": {
                "pattern": "^\\."
              },
              "default": {}
            },
            "headers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "pattern": {
                    "type": "string",
                    "minLength": 1
                  },
                  "headers": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    },
                    "propertyNames": {
                      "minLength": 1
                    }
                  }
                },
                "required": [
                  "pattern",
                  "headers"
                ],
                "additionalProperties": false
              },
              "default": []
            },
            "edgeRules": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string",
                    "minLength": 1
                  },
                  "actionType": {
                    "type": "string",
                    "enum": [
                      "ForceSSL",
                      "Redirect",
                      "OriginUrl",
                      "OverrideCacheTime",
                      "BlockRequest",
                      "SetResponseHeader",
                      "SetRequestHeader",
                      "ForceDownload",
                      "DisableTokenAuthentication",
                      "EnableTokenAuthentication",
                      "OverrideCacheTimePublic",
                      "IgnoreCacheControl",
                      "DisableCors",
                      "EnableCors",
                      "BypassPermaCache",
                      "OverrideBrowserCacheTime"
                    ]
                  },
                  "actionParameter1": {
                    "type": "string"
                  },
                  "actionParameter2": {
                    "type": "string"
                  },
                  "triggerType": {
                    "type": "string",
                    "enum": [
                      "Url",
                      "RequestHeader",
                      "ResponseHeader",
                      "UrlExtension",
                      "CountryCode",
                      "RemoteIP",
                      "StatusCode"
                    ]
                  },
                  "triggerPatterns": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "minItems": 1
                  },
                  "triggerMatchingType": {
                    "type": "string",
                    "enum": [
                      "Any",
                      "All",
                      "None"
                    ],
                    "default": "Any"
                  },
                  "enabled": {
                    "type": "boolean",
                    "default": true
                  }
                },
                "required": [
                  "description",
                  "actionType",
                  "actionParameter1",
                  "triggerType",
                  "triggerPatterns"
                ],
                "additionalProperties": false
              },
              "default": []
            },
            "storageZone": {
              "type": "string",
              "minLength": 1
            },
            "region": {
              "type": "string",
              "enum": [
                "ny",
                "la",
                "sg",
                "syd",
                "uk",
                "se",
                "br",
                "jh"
              ]
            },
            "concurrency": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 64,
              "default": 8
            },
            "pullZones": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  "purge": {
                    "anyOf": [
                      {
                        "type": "string",
                        "const": "all"
                      },
                      {
                        "type": "string",
                        "const": "none"
                      },
                      {
                        "type": "string",
                        "pattern": "^tag\\:"
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "minItems": 1
                      }
                    ],
                    "default": "all"
                  },
                  "tag": {
                    "type": "string"
                  }
                },
                "required": [
                  "id"
                ],
                "additionalProperties": false
              },
              "default": []
            }
          },
          "required": [
            "publicDir",
            "storageZone"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "deploy"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
