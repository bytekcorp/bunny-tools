    expect(parseAccountString('storage:')).toBeNull();
    expect(parseAccountString('unknown:foo')).toBeNull();
  });

  it('parseScopeFlag throws on bad input', () => {
    expect(() => parseScopeFlag('not-real')).toThrowError(/Invalid --scope/);
  });
});
