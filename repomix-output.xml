    storage.intercept({ path: '/my-app/index.html', method: 'PUT' }).reply(201, '');
    storage.intercept({ path: '/my-app/app.js', method: 'PUT' }).reply(201, '');
    storage.intercept({ path: '/my-app/gone.txt', method: 'DELETE' }).reply(204, '');
